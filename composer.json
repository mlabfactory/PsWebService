{
    "name": "dolcezampa/webservice",
    "description": "defines the dependencies required for a PHP microservice in a Dolce Zampa application",
    "type": "none",
    "license": "AGPL",
    "require": {
        "php": "^8.1",
        "slim/slim": "^4.13",
        "doctrine/dbal": "^4.0",
        "symfony/var-dumper": "^7.0",
        "ramsey/uuid": "^4.7",
        "vlucas/phpdotenv": "^5.6",
        "illuminate/database": "^11.0",
        "laravel/serializable-closure": "^1.3",
        "symfony/serializer": "^7.0",
        "robmorgan/phinx": "^0.16.0",
        "slim/http": "^1.3",
        "slim/psr7": "^1.6",
        "psr/log": "^3.0",
        "illuminate/events": "^11.0",
        "symfony/property-access": "^7.0",
        "illuminate/filesystem": "^11.0",
        "nesbot/carbon": "^3.2",
        "logtail/monolog-logtail": "^3.1",
        "bref/bref": "~2.4.1",
        "php-di/php-di": "^7.1",
        "guzzlehttp/guzzle": "^7.10",
        "illuminate/cache": "^11.51"
    },
    "require-dev": {
        "nikic/php-parser": "^5.0",
        "fakerphp/faker": "^1.23",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "DolzeZampa\\WS\\": "src/"
        },
        "files": [
            "config/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "Marco De Felice",
            "email": "marco.defelice@mlabfactory.it"
        }
    ],
    "minimum-stability": "stable"
}
